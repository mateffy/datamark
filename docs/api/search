nation/ast-68","page_id":"/docs/explanation/ast","tags":[],"type":"text","url":"/docs/explanation/ast#inline-nodes","content":"`children: InlineNode[]`"},"146":{"id":"/docs/explanation/ast-69","page_id":"/docs/explanation/ast","tags":[],"type":"text","url":"/docs/explanation/ast#positions","content":"Every node carries an optional `position` with start and end line/column:"},"147":{"id":"/docs/explanation/ast-70","page_id":"/docs/explanation/ast","tags":[],"type":"text","url":"/docs/explanation/ast#positions","content":"Positions are computed relative to the original input string, even when frontmatter is stripped. This means errors and traces point to the right place in your source file."},"148":{"id":"/docs/explanation/combinators","page_id":"/docs/explanation/combinators","type":"page","content":"Combinators","breadcrumbs":["datamark","Explanation"],"tags":[],"url":"/docs/explanation/combinators"},"149":{"id":"/docs/explanation/combinators-0","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators","content":"How node matchers, combinator modifiers, and structural combinators work under the hood."},"150":{"id":"/docs/explanation/combinators-1","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#node-matchers","content":"Node matchers"},"151":{"id":"/docs/explanation/combinators-2","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#combinator-modifiers","content":"Combinator modifiers"},"152":{"id":"/docs/explanation/combinators-3","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#optionalmatcher","content":"`optional(matcher)`"},"153":{"id":"/docs/explanation/combinators-4","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#manymatcher","content":"`many(matcher)`"},"154":{"id":"/docs/explanation/combinators-5","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#repeatcount-matcher","content":"`repeat(count, matcher)`"},"155":{"id":"/docs/explanation/combinators-6","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#structural-combinators","content":"Structural combinators"},"156":{"id":"/docs/explanation/combinators-7","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#untilpredicate","content":"`until(predicate)`"},"157":{"id":"/docs/explanation/combinators-8","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#splitbycombinatorpredicate","content":"`splitByCombinator(predicate)`"},"158":{"id":"/docs/explanation/combinators-9","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#rest","content":"`rest()`"},"159":{"id":"/docs/explanation/combinators-10","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#sectiondepth","content":"`section(depth)`"},"160":{"id":"/docs/explanation/combinators-11","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#predicate-helpers","content":"Predicate helpers"},"161":{"id":"/docs/explanation/combinators-12","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#exceptpredicate","content":"`except(predicate)`"},"162":{"id":"/docs/explanation/combinators-13","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#anypredicates","content":"`any(...predicates)`"},"163":{"id":"/docs/explanation/combinators-14","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#allpredicates","content":"`all(...predicates)`"},"164":{"id":"/docs/explanation/combinators-15","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#how-consume-advances","content":"How consume advances"},"165":{"id":"/docs/explanation/combinators-16","page_id":"/docs/explanation/combinators","type":"heading","tags":[],"url":"/docs/explanation/combinators#error-handling","content":"Error handling"},"166":{"id":"/docs/explanation/combinators-17","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators","content":"A combinator is a function that transforms an array of block nodes into a result and a remaining slice. `null` means the combinator did not match."},"167":{"id":"/docs/explanation/combinators-18","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#node-matchers","content":"Matchers like `heading(1)` and `codeBlock()` are both predicates and combinators. They carry a `CombinatorSymbol` that the runner uses when you pass them to `doc.consume()`."},"168":{"id":"/docs/explanation/combinators-19","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#node-matchers","content":"This dual nature means you can reuse matchers in `filter`, `findAll`, and `splitBy` without writing separate predicate functions."},"169":{"id":"/docs/explanation/combinators-20","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#optionalmatcher","content":"Returns the value if it matches, or `undefined` if it doesn't. Never throws."},"170":{"id":"/docs/explanation/combinators-21","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#manymatcher","content":"Runs the combinator repeatedly until it fails. Returns all matches."},"171":{"id":"/docs/explanation/combinators-22","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#repeatcount-matcher","content":"Runs the combinator exactly `count` times. Throws if it can't match enough."},"172":{"id":"/docs/explanation/combinators-23","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#untilpredicate","content":"Consumes nodes until the predicate matches. Returns consumed nodes; the matched node stays in `remaining`."},"173":{"id":"/docs/explanation/combinators-24","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#splitbycombinatorpredicate","content":"Splits all remaining nodes by a predicate. Returns groups of nodes separated by matching nodes (which are discarded). Consumes everything."},"174":{"id":"/docs/explanation/combinators-25","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#splitbycombinatorpredicate","content":"`splitByCombinator` is the workhorse for section-based documents. Combine it with `heading(2)` to split a document into top-level sections, then map over each section to extract its contents."},"175":{"id":"/docs/explanation/combinators-26","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#rest","content":"Consumes all remaining nodes. Always succeeds."},"176":{"id":"/docs/explanation/combinators-27","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#sectiondepth","content":"Consumes a heading at the given depth plus all body nodes until the next heading of the same depth. The heading is included in the returned chunk. Fails if the first remaining node is not a matching heading."},"177":{"id":"/docs/explanation/combinators-28","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#exceptpredicate","content":"Negates a predicate. Useful with `until()` or `splitByCombinator()`."},"178":{"id":"/docs/explanation/combinators-29","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#anypredicates","content":"Returns `true` if any predicate matches."},"179":{"id":"/docs/explanation/combinators-30","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#allpredicates","content":"Returns `true` only if all predicates match."},"180":{"id":"/docs/explanation/combinators-31","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#how-consume-advances","content":"When you call `yield* doc.consume(heading(1))`, the runner:"},"181":{"id":"/docs/explanation/combinators-32","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#how-consume-advances","content":"Finds the first matching node in `remaining`"},"182":{"id":"/docs/explanation/combinators-33","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#how-consume-advances","content":"Returns it as `value`"},"183":{"id":"/docs/explanation/combinators-34","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#how-consume-advances","content":"Sets `remaining` to everything after the matched node"},"184":{"id":"/docs/explanation/combinators-35","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#how-consume-advances","content":"This means combinators are **cursor-advancing**. They don't just test — they consume."},"185":{"id":"/docs/explanation/combinators-36","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#error-handling","content":"When a combinator fails, the runner throws `TemplateParseError` with a message like:"},"186":{"id":"/docs/explanation/combinators-37","page_id":"/docs/explanation/combinators","tags":[],"type":"text","url":"/docs/explanation/combinators#error-handling","content":"The position is derived from the first unconsumed node, so you know exactly where parsing broke down."},"187":{"id":"/docs/explanation","page_id":"/docs/explanation","type":"page","content":"Explanation","breadcrumbs":["datamark","Explanation"],"tags":[],"url":"/docs/explanation"},"188":{"id":"/docs/explanation-0","page_id":"/docs/explanation","tags":[],"type":"text","url":"/docs/explanation","content":"Deep dives into datamark's architecture, design decisions, and internals."},"189":{"id":"/docs/explanation-1","page_id":"/docs/explanation","tags":[],"type":"text","url":"/docs/explanation","content":"<Card title=\"The AST\" description=\"Typed tree structure: Document, BlockNode, InlineNode\" href=\"/docs/explanation/ast\" />"},"190":{"id":"/docs/explanation-2","page_id":"/docs/explanation","tags":[],"type":"text","url":"/docs/explanation","content":"<Card title=\"Format SDK\" description=\"How generator-based parsing and serialization work\" href=\"/docs/explanation/template-system\" />"},"191":{"id":"/docs/explanation-3","page_id":"/docs/explanation","tags":[],"type":"text","url":"/docs/explanation","content":"<Card title=\"Combinators\" description=\"How consume, splitBy, many, optional, and friends work under the hood\" href=\"/docs/explanation/combinators\" />"},"192":{"id":"/docs/explanation-4","page_id":"/docs/explanation","tags":[],"type":"text","url":"/docs/explanation","content":"<Card title=\"Validation\" description=\"Standard Schema v1 support and error handling\" href=\"/docs/explanation/validation\" />"},"193":{"id":"/docs/explanation-5","page_id":"/docs/explanation","tags":[],"type":"text","url":"/docs/explanation","content":"<Card title=\"Trace & Test\" description=\"Debugging formats with trace and CI with test\" href=\"/docs/explanation/trace-and-test\" />"},"194":{"id":"/docs/explanation/template-system","page_id":"/docs/explanation/template-system","type":"page","content":"Format SDK","breadcrumbs":["datamark","Explanation"],"tags":[],"url":"/docs/explanation/template-system"},"195":{"id":"/docs/explanation/template-system-0","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system","content":"How the generator-based format system works, from parse runners to emit runners."},"196":{"id":"/docs/explanation/template-system-1","page_id":"/docs/explanation/template-system","type":"heading","tags":[],"url":"/docs/explanation/template-system#the-core-idea","content":"The core idea"},"197":{"id":"/docs/explanation/template-system-2","page_id":"/docs/explanation/template-system","type":"heading","tags":[],"url":"/docs/explanation/template-system#the-datamark-factory","content":"The `datamark()` factory"},"198":{"id":"/docs/explanation/template-system-3","page_id":"/docs/explanation/template-system","type":"heading","tags":[],"url":"/docs/explanation/template-system#how-yield-works","content":"How `yield*` works"},"199":{"id":"/docs/explanation/template-system-4","page_id":"/docs/explanation/template-system","type":"heading","tags":[],"url":"/docs/explanation/template-system#the-emit-runner","content":"The emit runner"},"200":{"id":"/docs/explanation/template-system-5","page_id":"/docs/explanation/template-system","type":"heading","tags":[],"url":"/docs/explanation/template-system#sub-context-parsing-with-generators","content":"Sub-context parsing with generators"},"201":{"id":"/docs/explanation/template-system-6","page_id":"/docs/explanation/template-system","type":"heading","tags":[],"url":"/docs/explanation/template-system#why-generators","content":"Why generators?"},"202":{"id":"/docs/explanation/template-system-7","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system","content":"The Format SDK is the heart of datamark. It lets you define a **format** — a reusable, bidirectional mapping between Markdown documents and typed objects."},"203":{"id":"/docs/explanation/template-system-8","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-core-idea","content":"Instead of writing imperative traversal code over an AST, you write a **generator function** where each `yield*` expression triggers a combinator against the remaining document nodes. The generator's return value becomes the parsed object."},"204":{"id":"/docs/explanation/template-system-9","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-core-idea","content":"This reads as:"},"205":{"id":"/docs/explanation/template-system-10","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-core-idea","content":"Get the frontmatter."},"206":{"id":"/docs/explanation/template-system-11","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-core-idea","content":"Consume the first H1 heading."},"207":{"id":"/docs/explanation/template-system-12","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-core-idea","content":"Return an object with the title text and frontmatter."},"208":{"id":"/docs/explanation/template-system-13","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-datamark-factory","content":"`datamark(config)` wraps your generator into a `Format<T>` with four methods:"},"209":{"id":"/docs/explanation/template-system-14","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-datamark-factory","content":"Method"},"210":{"id":"/docs/explanation/template-system-15","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-datamark-factory","content":"Purpose"},"211":{"id":"/docs/explanation/template-system-16","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-datamark-factory","content":"`parse(content)`"},"212":{"id":"/docs/explanation/template-system-17","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-datamark-factory","content":"Run the parse generator, validate against schema"},"213":{"id":"/docs/explanation/template-system-18","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-datamark-factory","content":"`stringify(data)`"},"214":{"id":"/docs/explanation/template-system-19","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-datamark-factory","content":"Run the emit generator, produce Markdown"},"215":{"id":"/docs/explanation/template-system-20","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-datamark-factory","content":"`trace(content)`"},"216":{"id":"/docs/explanation/template-system-21","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-datamark-factory","content":"Step-by-step log of what each combinator consumed"},"217":{"id":"/docs/explanation/template-system-22","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-datamark-factory","content":"`test()`"},"218":{"id":"/docs/explanation/template-system-23","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-datamark-factory","content":"Validate configured examples against parse + schema"},"219":{"id":"/docs/explanation/template-system-24","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#how-yield-works","content":"Inside the generator, `yield*` is the syntax for delegating to another generator. datamark's combinators return `Yieldable<T>` values — objects that carry a `_tag` and executable logic."},"220":{"id":"/docs/explanation/template-system-25","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#how-yield-works","content":"When the runner sees a `Yieldable`, it:"},"221":{"id":"/docs/explanation/template-system-26","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#how-yield-works","content":"Extracts the combinator name (e.g. `heading(1)`)"},"222":{"id":"/docs/explanation/template-system-27","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#how-yield-works","content":"Runs the combinator against `remaining` nodes"},"223":{"id":"/docs/explanation/template-system-28","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#how-yield-works","content":"Returns `{ value, remaining }` back into your generator"},"224":{"id":"/docs/explanation/template-system-29","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#how-yield-works","content":"Your generator receives `value` and continues"},"225":{"id":"/docs/explanation/template-system-30","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#how-yield-works","content":"If a combinator fails (returns `null`), the runner throws a `TemplateParseError` with the position in the original Markdown."},"226":{"id":"/docs/explanation/template-system-31","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-emit-runner","content":"The stringify generator works the same way but in reverse. It receives an `EmitContext` and a data object, then uses `yield*` with emit combinators to build nodes:"},"227":{"id":"/docs/explanation/template-system-32","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#the-emit-runner","content":"The emit runner collects nodes into an array, then serializes the document with `stringify(doc)`."},"228":{"id":"/docs/explanation/template-system-33","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#sub-context-parsing-with-generators","content":"For documents split into sections (e.g. H2-delimited steps), pass a generator as the second argument to `consume()` to run it on each chunk:"},"229":{"id":"/docs/explanation/template-system-34","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#sub-context-parsing-with-generators","content":"`splitByCombinator(heading(2))` returns `BlockNode[][]`, so the generator runs once per chunk and the results are collected into an array. For flat combinators (like `until(heading(2))`), the generator runs once on a single sub-context."},"230":{"id":"/docs/explanation/template-system-35","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#why-generators","content":"Generators let us pause execution between each combinator, inspect what was consumed, and inject synthetic values for tracing. They also read naturally: the code looks like a step-by-step recipe for consuming a document."},"231":{"id":"/docs/explanation/template-system-36","page_id":"/docs/explanation/template-system","tags":[],"type":"text","url":"/docs/explanation/template-system#why-generators","content":"See Combinators for how individual combinators work."},"232":{"id":"/docs/explanation/trace-and-test","page_id":"/docs/explanation/trace-and-test","type":"page","content":"Trace & Test","breadcrumbs":["datamark","Explanation"],"tags":[],"url":"/do