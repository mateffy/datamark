{
  "name": "@datamark/documentation",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && mv .output/dist/client/ .output/public/ && cp ../skill/skills/struktur/SKILL.md .output/public/skill.md && cp .output/public/CNAME .output/public/docs/CNAME && mv .output/public/client/__tsr .output/public/__tsr && rmdir .output/public/client && touch .output/public/.nojekyll && rm -rf ../../docs && cp -r .output/public ../../docs",
    "start": "serve .output/public --config ../../serve.json",
    "preview": "vite preview",
    "types:check": "fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@tanstack/react-router": "1.160.2",
    "@tanstack/react-router-devtools": "1.160.2",
    "@tanstack/react-start": "1.160.2",
    "@tanstack/start-static-server-functions": "1.160.2",
    "fumadocs-core": "16.6.4",
    "fumadocs-mdx": "14.2.7",
    "fumadocs-ui": "16.6.4",
    "lucide-react": "^0.570.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.1",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "agentation": "^2.2.1",
    "nitro": "3.0.1-alpha.2",
    "serve": "^14.2.5",
    "srvx": "^0.11.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
